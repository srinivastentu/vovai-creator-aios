# VOVAI eLearn AIOS — Environment Variables
# Copy to .env.local: cp .env.example .env.local

# Database (PostgreSQL via Homebrew)
DATABASE_URL="postgresql://$(whoami)@localhost:5432/vovai_elearn_dev"
REDIS_URL="redis://localhost:6379"

# ─── AI Providers ──────────────────────────────────────────────────────────

# Anthropic — unlocks Claude agents (producer for text/image prompts)
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI — unlocks dall-e-3-standard, dall-e-3-hd, gpt-4o-vision judge, text judge
OPENAI_API_KEY="sk-..."

# fal.ai — unlocks flux-dev, flux-pro (env var name matches provider client; do NOT rename)
FAL_KEY=""

# Google Gemini — unlocks nanobanan-pro (image generation)
GOOGLE_GEMINI_API_KEY=""

# Freepik — unlocks freepik-mystic (image generation)
FREEPIK_API_KEY=""

# ElevenLabs — required for Phase 5.1 voice generation
ELEVENLABS_API_KEY=""

# ─── Cost guards ───────────────────────────────────────────────────────────

# Optional per-project ideation cost ceiling (USD). Blank = unlimited.
IDEATION_COST_LIMIT_USD=""

# ─── Auth (future) ─────────────────────────────────────────────────────────
# CLERK_SECRET_KEY="..."

# ─── Storage (local in dev, S3 in production) ──────────────────────────────
MEDIA_STORAGE_PATH="./storage"
