# VOVAI CreatorOS — Environment Variables
# Copy to .env.local: cp .env.example .env.local

# Database (PostgreSQL via Homebrew)
DATABASE_URL="postgresql://$(whoami)@localhost:5432/vovai_creator_dev"

# ─── AI Providers (V1) ─────────────────────────────────────────────────────

# Anthropic — Claude producers + web_search research
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI — GPT producer + text-embedding-3-large (acceptance-test similarity)
OPENAI_API_KEY="sk-..."

# Google Gemini — cross-critique judge (third model family, no self-preference)
GOOGLE_GEMINI_API_KEY=""

# ─── Auth (future) ─────────────────────────────────────────────────────────
# CLERK_SECRET_KEY="..."   # V2 — V1 uses a hardcoded local user

# V2+ provider keys — add when those phases land.
# See docs/01-architecture/mms-architecture.md for the full
# provider catalog.
#   FAL_KEY                  — image generation (V2)
#   FREEPIK_API_KEY          — image generation (V2)
#   ELEVENLABS_API_KEY       — voice synthesis (V4)
#   MEDIA_STORAGE_PATH       — local media cache (V2+)
#   REDIS_URL                — BullMQ queue (V2+ multi-tenant)
#   IDEATION_COST_LIMIT_USD  — per-pipeline budget cap (V2+)
