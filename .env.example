# VOVAI eLearn AIOS — Environment Variables
# Copy to .env.local: cp .env.example .env.local

# Database (PostgreSQL via Homebrew)
DATABASE_URL="postgresql://$(whoami)@localhost:5432/vovai_elearn_dev"
REDIS_URL="redis://localhost:6379"

# AI Providers
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
FAL_API_KEY="..."
ELEVENLABS_API_KEY="..."

# Auth (add later in Ring 5)
# CLERK_SECRET_KEY="..."

# Storage (local in dev, S3 in production)
MEDIA_STORAGE_PATH="./storage"
