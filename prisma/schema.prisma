// VOVAI eLearn AIOS — Prisma Schema
// Models derived from src/lib/types.ts
// Ring 1 schema — covers the full recursive loop engine

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  draft
  in_progress
  completed
}

enum SessionStatus {
  idle
  generating
  evaluating
  presenting
  awaiting_review
  approved
}

enum IterationOutcome {
  revised
  presented
  escalated
  approved
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Project {
  id              String         @id @default(uuid())
  name            String
  topic           String
  targetAudience  String
  durationMinutes Int
  status          ProjectStatus  @default(draft)
  currentRing     Int            @default(0)
  totalCostUSD    Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  stageSessions   StageSession[]
  blueprint       ProjectBlueprint?
}

model StageSession {
  id                String           @id @default(uuid())
  projectId         String
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId           Int
  status            SessionStatus    @default(idle)
  currentArtifactId String?
  bestArtifactId    String?
  bestGrade         Json?            // Grade struct stored as JSON
  metadata          Json?            // Orchestration context (batch info, pipeline hints)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  artifacts         Artifact[]
  iterations        IterationRecord[]
  nodeComponents    NodeComponent[]

  @@index([projectId])
}

// Artifact — immutable. New version = new row. Never update content.
model Artifact {
  id             String        @id @default(uuid())
  stageSessionId String
  stageSession   StageSession  @relation(fields: [stageSessionId], references: [id], onDelete: Cascade)
  version        Int
  content        String        // script text, image URL, file path, etc.
  stage          String
  sceneIndex     Int?
  createdAt      DateTime      @default(now())
  metadata       Json          @default("{}")

  @@index([stageSessionId])
  @@unique([stageSessionId, version])
}

// IterationRecord — one row per loop iteration. Grade + cost embedded.
model IterationRecord {
  id               String           @id @default(uuid())
  stageSessionId   String
  stageSession     StageSession     @relation(fields: [stageSessionId], references: [id], onDelete: Cascade)
  artifactId       String
  iteration        Int
  grade            Json             // Grade { dimensions[], compositeScore, ... }
  outcome          IterationOutcome
  costModel        String
  costInputTokens  Int
  costOutputTokens Int
  costUSD          Float
  createdAt        DateTime         @default(now())

  @@index([stageSessionId])
}

// ─── Project Component Layer — Enums ──────────────────────────────────────────

enum ProjectArchetype {
  k12_curriculum
  professional_training
  content_channel
}

enum NodeStatus {
  draft
  ideating
  structured
  approved
  in_production
  completed
}

enum ComponentStatus {
  planned
  configured
  queued
  in_production
  completed
  skipped
}

enum ComponentPriority {
  core
  recommended
  optional
}

enum IdeationPhase {
  brainstorm
  structure
  refinement
  review
  approved
}

enum BrainstormRole {
  human
  facilitator
  researcher
  pedagogy_expert
  audience_analyst
  structure_architect
  creative_director
  critic
  synthesizer
}

enum GradeRecommendation {
  approve
  revise
  restructure
  reject
}

// ─── Project Component Layer — Models ─────────────────────────────────────────

model ProjectBlueprint {
  id                String            @id @default(uuid())
  projectId         String            @unique
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  archetype         ProjectArchetype  @default(professional_training)
  hierarchyLabels   Json              // {"level0":"Course","level1":"Module","level2":"Topic","level3":"Subtopic"}
  targetAudience    Json              // Detailed audience profile
  learningOutcomes  Json              // High-level learning outcomes array
  enabledComponents Json              // ["video","quiz","study_material","activity","capstone"]
  workflowTemplate  Json?             // WorkflowTemplate: enabledComponents, productionOrder, levelDefaults
  ideationPhase     IdeationPhase     @default(brainstorm)
  ideationScore     Float?
  structureSummary  Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  nodes             ProjectNode[]
  conversations     IdeationConversation[]
  versions          BlueprintVersion[]
  grades            StructureGrade[]
}

model ProjectNode {
  id               String            @id @default(uuid())
  blueprintId      String
  blueprint        ProjectBlueprint  @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  parentId         String?
  parent           ProjectNode?      @relation("NodeTree", fields: [parentId], references: [id], onDelete: SetNull)
  children         ProjectNode[]     @relation("NodeTree")
  title            String
  slug             String
  description      String?
  notes            String?
  depth            Int               @default(0)
  sortOrder        Int               @default(0)
  learningOutcomes Json              @default("[]")
  status           NodeStatus        @default(draft)
  agentConfidence  Float?
  path             String            // Materialized path: "/module-1/topic-2/subtopic-1"
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  components       NodeComponent[]

  @@unique([blueprintId, path])
  @@index([blueprintId, depth])
  @@index([parentId])
}

model NodeComponent {
  id              String            @id @default(uuid())
  nodeId          String
  node            ProjectNode       @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  componentType   String            // "video","quiz","study_material","activity","capstone"
  config          Json              @default("{}")
  priority        ComponentPriority @default(core)
  status          ComponentStatus   @default(planned)
  relevanceScore  Float?
  pipelineJobId   String?
  pipelineJob     StageSession?     @relation(fields: [pipelineJobId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([nodeId])
  @@index([pipelineJobId])
}

model IdeationConversation {
  id           String            @id @default(uuid())
  blueprintId  String
  blueprint    ProjectBlueprint  @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  phase        IdeationPhase
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  messages     IdeationMessage[]

  @@index([blueprintId])
}

model IdeationMessage {
  id              String                @id @default(uuid())
  conversationId  String
  conversation    IdeationConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            BrainstormRole
  messageType     String                // "text","suggestion","question","decision","structure_update"
  content         String
  structuredData  Json?
  createdAt       DateTime              @default(now())

  @@index([conversationId])
}

model BlueprintVersion {
  id           String            @id @default(uuid())
  blueprintId  String
  blueprint    ProjectBlueprint  @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  version      Int
  snapshot     Json              // Full blueprint + nodes + components snapshot
  rubricScore  Json?
  createdAt    DateTime          @default(now())

  @@unique([blueprintId, version])
}

model StructureGrade {
  id              String              @id @default(uuid())
  blueprintId     String
  blueprint       ProjectBlueprint    @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  overallScore    Float
  dimensionScores Json                // 7 dimensions: coverage, depth, progression, balance, engagement, feasibility, coherence
  recommendation  GradeRecommendation
  feedback        String?
  createdAt       DateTime            @default(now())

  @@index([blueprintId])
}
