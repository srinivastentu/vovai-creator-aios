{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VOVAI Rubric Schema",
  "type": "object",
  "required": ["name", "domain", "stage", "dimensions"],
  "properties": {
    "name": { "type": "string" },
    "domain": { "type": "string" },
    "stage": { "type": "string" },
    "dimensions": {
      "type": "array", "minItems": 5, "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["name", "weight", "description", "scoreLevels"],
        "properties": {
          "name": { "type": "string" },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "description": { "type": "string" },
          "scoreLevels": {
            "type": "object",
            "required": ["1-3", "4-6", "7-8", "9-10"]
          }
        }
      }
    }
  }
}
