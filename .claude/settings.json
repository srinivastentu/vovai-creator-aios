{
  "permissions": {
    "allow": [
      "npm test", "npm run test:unit", "npm run lint", "npm run typecheck",
      "npm run build", "npm run dev",
      "npx prisma *",
      "git status", "git diff *", "git add *", "git commit *", "git push *",
      "git log *", "git branch *", "git checkout *",
      "ffmpeg -version", "ffprobe *",
      "brew list", "brew info *"
    ],
    "deny": ["rm -rf /", "rm -rf ~", "npm run db:reset"]
  }
}
