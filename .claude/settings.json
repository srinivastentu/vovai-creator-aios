{
  "permissions": {
    "allow": [
      "npm test", "npm run test:unit", "npm run lint", "npm run typecheck",
      "npm run build", "npm run dev",
      "npx prisma *",
      "git status", "git diff *", "git add *", "git commit *", "git push *",
      "git log *", "git branch *", "git checkout *",
      "ffmpeg -version", "ffprobe *",
      "brew list", "brew info *"
    ],
    "deny": ["rm -rf /", "rm -rf ~", "npm run db:reset"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "npm run lint --fix 2>/dev/null || true" }]
      }
    ],
    "PreCommit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "npm run typecheck" },
          { "type": "command", "command": "npm run test -- --bail" }
        ]
      }
    ]
  },
  "env": { "MAX_THINKING_TOKENS": "10000" }
}
